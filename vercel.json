{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:; script-src * 'unsafe-inline' 'unsafe-eval';"
        }
      ]
    }
  ],
  "functions": {
    "api/analyse.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/notify-deadlines",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/notify-conversion",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/notify-inactive",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/notify-pro-monthly",
      "schedule": "0 9 10 * *"
    },
    {
      "path": "/api/notify-seasonal-insurance-pro",
      "schedule": "0 9 1 10 *"
    },
    {
      "path": "/api/notify-seasonal-insurance-free",
      "schedule": "0 10 1 10 *"
    },
    {
      "path": "/api/notify-limit-reached",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/notify-upgrade-amigos45",
      "schedule": "0 11 * * 1"
    }
  ]
}